# Required environment variables for dice-tracker
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git

# Supabase
SUPABASE_URL=https://zziindzdwzlmnkccenfx.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# Gmail SMTP alerts
# GMAIL_ADDRESS: Gmail account that SENDS alerts — must have App Password enabled
# ALERT_TO_EMAIL: email that RECEIVES alerts — can be any email address
GMAIL_ADDRESS=your_sender_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here
ALERT_TO_EMAIL=your_receiver_email@example.com

# Optional: SerpAPI for Google Shopping (free tier = 100 searches/month)
SERPAPI_KEY=your_serpapi_key_here

# Alert thresholds
MIN_SIZE_MM=50
MAX_PRICE_USD=150
ALERT_ON_NEW=true
ALERT_ON_PRICE_DROP=true
PRICE_DROP_THRESHOLD_PCT=5
